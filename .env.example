NODE_ENV=development

FRONTEND_PORT=3000
BACKEND_PORT=3001
# Empty means the frontend uses same-origin /api. This is recommended for Docker/nginx.
VITE_API_BASE_URL=
# Optional Docker build-time override. Leave empty to use nginx /api proxy.
DOCKER_VITE_API_BASE_URL=
VITE_DEV_PROXY_TARGET=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

DATABASE_PATH=/data/book-manager.sqlite
LOOKUP_CACHE_TTL_DAYS=30

# Optional. Used to identify this self-hosted app to external metadata APIs.
OPEN_LIBRARY_APP_NAME=
OPEN_LIBRARY_CONTACT=
